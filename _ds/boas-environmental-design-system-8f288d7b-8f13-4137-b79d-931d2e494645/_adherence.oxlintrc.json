{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/layout/**",
              "components/navigation/**",
              "ui_kits/website/**",
              "ui_kits/website/pages/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|icon|onDismiss|children|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: tone, title, icon, onDismiss, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|danger|info|neutral)$/]",
        "message": "<Alert> tone must be one of 'ok' | 'warn' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, size, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ok|warn|danger|info|neutral|brand)$/]",
        "message": "<Badge> tone must be one of 'ok' | 'warn' | 'danger' | 'info' | 'neutral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BreadcrumbItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|href|key|ref|className|style|children)$/]",
        "message": "<BreadcrumbItem> doesn't accept that prop. Declared props: label, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|iconLeft|iconRight|fullWidth|loading|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, iconLeft, iconRight, fullWidth, loading."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger|brand-inverse)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger' | 'brand-inverse'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|header|footer|interactive|onClick|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, header, footer, interactive, onClick, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|raised|sunken|brand)$/]",
        "message": "<Card> variant must be one of 'default' | 'raised' | 'sunken' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='padding'] > Literal[value!=/^(?:none|sm|md|lg)$/]",
        "message": "<Card> padding must be one of 'none' | 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:indeterminate|children|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: indeterminate, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:key|header|align|width|mono|render|key|ref|className|style|children)$/]",
        "message": "<DataTableColumn> doesn't accept that prop. Declared props: key, header, align, width, mono, render."
      },
      {
        "selector": "JSXOpeningElement[name.name='DataTableColumn'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center|right)$/]",
        "message": "<DataTableColumn> align must be one of 'left' | 'center' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute > JSXIdentifier[name!=/^(?:orientation|label|key|ref|className|style|children)$/]",
        "message": "<Divider> doesn't accept that prop. Declared props: orientation, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Divider'] > JSXAttribute[name.name='orientation'] > Literal[value!=/^(?:horizontal|vertical)$/]",
        "message": "<Divider> orientation must be one of 'horizontal' | 'vertical'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FormField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|htmlFor|helper|error|required|children|key|ref|className|style|children)$/]",
        "message": "<FormField> doesn't accept that prop. Declared props: label, htmlFor, helper, error, required, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|pressed|ariaLabel|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: variant, size, disabled, pressed, ariaLabel, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<IconButton> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|addonLeft|addonRight|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, invalid, addonLeft, addonRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|status|size|showLabel|labelPosition|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, status, size, showLabel, labelPosition."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:ok|warn|danger|neutral|brand)$/]",
        "message": "<ProgressBar> status must be one of 'ok' | 'warn' | 'danger' | 'neutral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<ProgressBar> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='labelPosition'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<ProgressBar> labelPosition must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Readout'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|unit|size|status|align|key|ref|className|style|children)$/]",
        "message": "<Readout> doesn't accept that prop. Declared props: value, unit, size, status, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='Readout'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Readout> size must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Readout'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:ok|warn|danger|neutral|brand)$/]",
        "message": "<Readout> status must be one of 'ok' | 'warn' | 'danger' | 'neutral' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Readout'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:baseline|center)$/]",
        "message": "<Readout> align must be one of 'baseline' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|placeholder|options|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: size, invalid, placeholder, options."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Select> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|trend|trendLabel|positiveIntent|tone|icon|footer|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, unit, trend, trendLabel, positiveIntent, tone, icon, footer."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='positiveIntent'] > Literal[value!=/^(?:up|down)$/]",
        "message": "<StatCard> positiveIntent must be one of 'up' | 'down'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|brand|sunken)$/]",
        "message": "<StatCard> tone must be one of 'default' | 'brand' | 'sunken'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabsItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|badge|disabled|key|ref|className|style|children)$/]",
        "message": "<TabsItem> doesn't accept that prop. Declared props: id, label, icon, badge, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:content|placement|delay|children|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: content, placement, delay, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> placement must be one of 'top' | 'bottom' | 'left' | 'right'."
      }
    ]
  },
